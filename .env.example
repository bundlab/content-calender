# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=content_calender_db
POSTGRES_HOST=db  # 'db' for Docker Compose, or localhost for local
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
JWT_SECRET_KEY=your_jwt_secret_key_here  # Generate with: openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend
VITE_API_BASE_URL=http://localhost:8000  # Backend URL for dev

# CORS (for development)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
